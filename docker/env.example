# Optional: copy to .env in the repo root (gitignored by *.env) or export before `docker compose up`.
# Java (host): loopback + high port so nginx stream can bind :25565 (see docker/README.md).
# MC_HOST_BIND=127.0.0.1
# MC_HOST_PORT=25566
# MC_SERVER_PORT=25565
# RCON (host): keep loopback unless you fully understand the risk of WAN exposure.
# MC_RCON_HOST_BIND=127.0.0.1
# MC_RCON_HOST_PORT=25575
# MC_RCON_PORT=25575
# MC_BEDROCK_HOST_PORT=19132
# MC_MIN_MEM=8G
# MC_MAX_MEM=8G
# RCON_PASSWORD=change-me
